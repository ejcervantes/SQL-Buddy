# Control de versiones
.git
.gitignore

# Dependencias / builds (se regeneran dentro de la imagen)
**/node_modules
**/dist
frontend/dist

# Python
**/__pycache__
**/*.py[cod]
**/.venv
**/venv

# Secretos y entornos
**/.env
**/.env.*
!**/.env.example

# Base vectorial persistente (se re-siembra al arrancar)
**/chroma_db
**/chroma_db_*

# Varios
**/.DS_Store
**/*.log
.claude
scratchpad
