# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# --- Base vectorial (ChromaDB) ---
CHROMA_PERSIST_DIRECTORY=./chroma_db

# --- Base de datos (Postgres / Supabase) ---
# Si se define, el backend introspecta el esquema en vivo al arrancar.
# Si se deja vacía, se usa backend/app/metadata_seed.json como respaldo.
# En Supabase: Project Settings -> Database -> Connection string (URI).
DATABASE_URL=postgresql://usuario:password@host:5432/postgres
DB_SCHEMA=public

# --- Servidor ---
PORT=8000
HOST=0.0.0.0
# Orígenes permitidos para CORS, separados por coma. "*" permite todos.
ALLOWED_ORIGINS=*
