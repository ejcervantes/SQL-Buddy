# URL del backend (FastAPI). En local suele ser http://localhost:8000
VITE_API_URL=http://localhost:8000

# Credenciales de Supabase (proyecto -> Settings -> API)
# La anon key es pública por diseño (se envía al navegador y se protege con RLS),
# pero se mantiene fuera del código para no versionarla y poder cambiarla por entorno.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
